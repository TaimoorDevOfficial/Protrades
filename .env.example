PROTRADES_SECRET=replace-with-long-random-secret
DATABASE_URL=sqlite:///./protrades.db
# Rupeezy Vortex API base (official SDK default — wrong host causes DNS errors e.g. getaddrinfo failed)
RUPEEZZY_BASE=https://vortex-api.rupeezy.in/v2
# 1 = skip real HTTP to Rupeezzy (demo data). 0 = live login; requires working DNS/network to RUPEEZZY_BASE
RUPEEZZY_MOCK=1
# 1 = shared public session: anyone visiting sees the same broker session (NOT secure)
PUBLIC_MODE=0
# Rupeezy Vortex credentials (server-side only)
VORTEX_APPLICATION_ID=
VORTEX_X_API_KEY=
CLAUDE_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080
PUBLIC_APP_URL=https://app.protrades.in
# When NSE returns 403 from your host, save a JSON array from the browser into this file and set path (repo-relative ok)
NSE_CA_FALLBACK_JSON_PATH=
# Optional: Cookie header from browser DevTools after opening nseindia.com (may reduce 403; refresh when it expires)
NSE_CA_COOKIE=
